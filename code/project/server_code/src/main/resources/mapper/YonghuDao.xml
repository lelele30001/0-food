<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.cl.dao.YonghuDao">

    <!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.cl.entity.YonghuEntity" id="yonghuMap">
        <result property="yonghuzhanghao" column="yonghuzhanghao"/>
        <result property="yonghumima" column="yonghumima"/>
        <result property="yonghuxingming" column="yonghuxingming"/>
        <result property="touxiang" column="touxiang"/>
        <result property="xingbie" column="xingbie"/>
        <result property="shoujihaoma" column="shoujihaoma"/>
        <result property="shenfenzheng" column="shenfenzheng"/>
        <result property="youxiang" column="youxiang"/>
        <result property="shengao" column="shengao"/>
        <result property="tizhong" column="tizhong"/>
        <result property="nianling" column="nianling"/>
        <result property="jianshenmubiao" column="jianshenmubiao"/>
        <result property="yinsjijin" column="yinsjijin"/>
        <result property="meirireliang" column="meirireliang"/>
    </resultMap>

    <select id="selectListView"
            resultType="com.cl.entity.view.YonghuView">

        SELECT yonghu.* FROM yonghu yonghu
        <where>1=1 ${ew.sqlSegment}</where>
    </select>

    <select id="selectView"
            resultType="com.cl.entity.view.YonghuView">
        SELECT * FROM yonghu yonghu
        <where>1=1 ${ew.sqlSegment}</where>
    </select>

    <update id="update" parameterType="com.cl.entity.YonghuEntity">
        update yonghu set
            yonghuzhanghao = #{yonghuzhanghao},
            yonghumima = #{yonghumima},
            yonghuxingming = #{yonghuxingming},
            touxiang = #{touxiang},
            xingbie = #{xingbie},
            shoujihaoma = #{shoujihaoma},
            shenfenzheng = #{shenfenzheng},
            youxiang = #{youxiang},
            shengao = #{shengao},
            tizhong = #{tizhong},
            nianling = #{nianling},
            jianshenmubiao = #{jianshenmubiao},
            yinsjijin = #{yinsjijin},
            meirireliang = #{meirireliang}
        where id = #{id}
    </update>

</mapper>
