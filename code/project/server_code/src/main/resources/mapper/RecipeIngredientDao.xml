<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.cl.dao.RecipeIngredientDao" >
  <resultMap id="BaseResultMap" type="com.cl.entity.RecipeIngredientEntity" >
    <id column="id" property="id" />
    <result column="recipe_id" property="recipeId" />
    <result column="ingredient_code" property="ingredientCode" />
    <result column="ingredient_name" property="ingredientName" />
    <result column="weight" property="weight" />
    <result column="unit" property="unit" />
    <result column="base_calories" property="baseCalories" />
    <result column="calories" property="calories" />
  </resultMap>
  
  <sql id="Base_Column_List" >
    id, recipe_id, ingredient_code, ingredient_name, weight, unit, base_calories, calories
  </sql>
  
  <select id="selectByRecipeId" resultMap="BaseResultMap" parameterType="java.lang.Long" >
    select 
    <include refid="Base_Column_List" />
    from recipe_ingredient
    where recipe_id = #{recipeId}
  </select>
  
  <insert id="batchInsert" parameterType="java.util.List" >
    insert into recipe_ingredient (recipe_id, ingredient_code, ingredient_name, weight, unit, base_calories, calories)
    values
    <foreach collection="list" item="item" separator="," >
      (#{item.recipeId}, #{item.ingredientCode}, #{item.ingredientName}, #{item.weight}, #{item.unit}, #{item.baseCalories}, #{item.calories})
    </foreach>
  </insert>
</mapper>